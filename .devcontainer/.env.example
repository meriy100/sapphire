# Fine-grained personal access token for GitHub.
#   Repository access: Only select repositories -> meriy100/sapphire
#   Permissions (minimum suggested):
#     - Contents: Read and write
#     - Pull requests: Read and write
#     - Issues: Read and write
#     - Metadata: Read-only (always required)
# Copy this file to .devcontainer/.env and fill in the token below.
# .devcontainer/.env is gitignored; never commit it.
GITHUB_TOKEN=
GH_TOKEN=
