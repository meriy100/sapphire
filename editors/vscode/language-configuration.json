{
  "comments": {
    "lineComment": "--",
    "blockComment": ["{-", "-}"]
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "{-", "close": "-}", "notIn": ["string", "comment"] }
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "wordPattern": "[A-Za-z_][A-Za-z0-9_']*",
  "indentationRules": {
    "increaseIndentPattern": "(^\\s*(let|where|do|of)\\s*$|\\b(where|do|of)\\s*$|=\\s*$|->\\s*$|\\bthen\\s*$|\\belse\\s*$|\\bin\\s*$|\\(\\s*$|\\[\\s*$|\\{\\s*$)",
    "decreaseIndentPattern": "^\\s*(\\)|\\]|\\})"
  },
  "onEnterRules": [
    {
      "beforeText": "^\\s*--",
      "action": { "indent": "none", "appendText": "-- " }
    }
  ]
}
